<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Memo</title>
</head>
<body>
    <h1>Edit Memo</h1>

    <form action="/memos/edit/<%= memo.id %>" method="post">
        <label for="title">Title:</label>
        <input type="text" id="title" name="title" value="<%= memo.title %>" required>
        <br>
        <label for="content">Content:</label>
        <textarea name="content" id="content" required><%= memo.content %></textarea>
        <br>
        <button type="submit">Update Memo</button>
    </form>
</body>
</html>